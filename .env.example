SMTP_FROM_ADDRESS=makerspace@example.com
EMAIL_PROVIDER=smtp
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_GMAIL_SENDER=
GOOGLE_SHEETS_SYNC_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET=PrintJobs
DEFAULT_PRINTER_NAME=Makerspace
SITE_ID=PT
PORT=5000

# Library hours enforcement
# Patrons cannot submit jobs outside open hours (+ post-close buffer).
# Set LIBRARY_HOURS_ENFORCE=false to disable entirely (e.g. local dev/testing).
# LIBRARY_SHORT_NAME and SERVICE_SHORT_NAME come from the NC State Libraries API:
#   https://www.lib.ncsu.edu/api/hours/everything.json
# Hill Library Makerspace : library_short_name=hill  service_short_name=makerspace
# Hunt Library Maker Studio: library_short_name=hunt  service_short_name=maker-studio
LIBRARY_HOURS_ENFORCE=true
LIBRARY_HOURS_LIBRARY_SHORT_NAME=hill
LIBRARY_HOURS_SERVICE_SHORT_NAME=makerspace
LIBRARY_HOURS_POST_CLOSE_BUFFER_MINUTES=10
GO_NCSU_API_TOKEN=
GO_NCSU_LINK_SLUG=makerspace-print-label
