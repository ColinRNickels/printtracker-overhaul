# Copy to .env.docker for local Docker Compose runtime
# cp .env.docker.example .env.docker

SECRET_KEY=local-dev-secret-change-me
STAFF_PASSWORD=staffpw

# Label and worker behavior for server/agent proof of concept
LABEL_PRINT_MODE=mock
WORKER_DISPATCH_ENABLED=true
AGENT_BOOTSTRAP_KEY=change-me-before-registering-a-pi
AGENT_POLL_BATCH_SIZE=5

# Must be reachable from phones and Pi workers on your LAN
# Example: http://192.168.1.50:5000
KIOSK_BASE_URL=http://localhost:5000

# Space routing
PRINT_TRACKER_SPACES=makerspace|Makerspace|MK|Makerspace,maker-studio|Maker Studio|MS|Maker Studio

# Local testing defaults
LIBRARY_HOURS_ENFORCE=false
GOOGLE_SHEETS_SYNC_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_FROM_ADDRESS=makerspace@example.com
