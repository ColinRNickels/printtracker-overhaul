SERVER_BASE_URL=http://192.168.1.50:5000
AGENT_ID=makerspace-pi-01
AGENT_BOOTSTRAP_KEY=change-me-before-first-run
AGENT_SPACE_SLUG=makerspace
AGENT_DISPLAY_NAME=Hill Makerspace Pi
AGENT_TOKEN_FILE=.state/pi-agent.token
AGENT_POLL_INTERVAL_SECONDS=5
AGENT_HEARTBEAT_INTERVAL_SECONDS=30
PI_AGENT_LOG_LEVEL=INFO

LABEL_PRINT_MODE=cups
LABEL_PRINTER_QUEUE=QL-800
LABEL_OUTPUT_DIR=labels
LABEL_STOCK=DK1202
LABEL_DPI=300
LABEL_ORIENTATION=landscape
LABEL_QR_PAYLOAD_MODE=url
LABEL_QR_SIZE_INCH=0.5
LABEL_BRAND_TEXT=NC State University Libraries Makerspace
LABEL_BRAND_LOGO_PATH=
LABEL_SIDE_ART_PATH=assets/noun-3d-printer-8112508.svg
LABEL_CUPS_MEDIA=62x100mm
LABEL_CUPS_EXTRA_OPTIONS=
LABEL_SAVE_LABEL_FILES=true
LABEL_RETENTION_DAYS=2